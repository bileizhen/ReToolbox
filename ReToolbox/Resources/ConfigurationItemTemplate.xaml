<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls">

    <Style x:Key="ConfigurationSettingsCardTemplate" TargetType="controls:SettingsCard">
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="MinHeight" Value="84" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
    </Style>

    <Style x:Key="ConfigurationSettingsExpanderTemplate" TargetType="controls:SettingsExpander">
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="MinHeight" Value="84" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
    </Style>

    <Style x:Key="CategoryTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,14,0,10" />
    </Style>

    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,24,0,24" />
    </Style>

    <Style
        x:Key="AtlasLikeSettingsCardTemplate"
        BasedOn="{StaticResource ConfigurationSettingsCardTemplate}"
        TargetType="controls:SettingsCard">
        <Setter Property="Margin" Value="0,0,36,10" />
        <Setter Property="MinHeight" Value="80" />
        <Setter Property="BorderBrush" Value="#0DFFFFFF" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style x:Key="SettingsCategoryTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

</ResourceDictionary>
