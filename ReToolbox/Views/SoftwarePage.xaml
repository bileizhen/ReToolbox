<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ReToolbox.Views.SoftwarePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Margin="55,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="9*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Name="TitleTxt"
            Grid.Row="0"
            Margin="0,24,36,24"
            FontSize="40"
            FontWeight="SemiBold"
            Text="安装软件" />

        <Grid Grid.Row="1">
            <ScrollViewer Height="Auto" VerticalAlignment="Top">
                <StackPanel x:Name="SoftwareListPanel" />
            </ScrollViewer>
        </Grid>

        <Button
            x:Name="InstallButton"
            Grid.Row="2"
            Margin="0,0,36,20"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Click="InstallSelected_Click"
            Content="安装"
            Style="{StaticResource AccentButtonStyle}"
            IsEnabled="{x:Bind ViewModel.IsInstalling, Mode=OneWay, Converter={StaticResource InvertBoolConverter}}" />

        <ContentDialog
            x:Name="InstallProgressDialog"
            Title="正在安装软件"
            DefaultButton="None">
            <StackPanel Width="500" Spacing="14">
                <TextBlock
                    FontWeight="SemiBold"
                    Text="{x:Bind ViewModel.CurrentItemText, Mode=OneWay}"
                    TextWrapping="Wrap" />

                <StackPanel Spacing="4">
                    <TextBlock
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="总体进度" />
                    <ProgressBar
                        Maximum="100"
                        Value="{x:Bind ViewModel.OverallProgress, Mode=OneWay}" />
                </StackPanel>

                <StackPanel
                    Spacing="4"
                    Visibility="{x:Bind ViewModel.IsDownloading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="下载进度" />
                    <ProgressBar
                        Maximum="100"
                        Value="{x:Bind ViewModel.DownloadProgress, Mode=OneWay}" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="日志" />
                    <ListView
                        x:Name="InstallLogListView"
                        Height="230"
                        Padding="6"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        ItemsSource="{x:Bind ViewModel.InstallLogs}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock
                                    FontFamily="Consolas"
                                    FontSize="12"
                                    Text="{Binding}"
                                    TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>
