<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ReToolbox.Views.SoftwarePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Margin="55,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="9*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Name="TitleTxt"
            Grid.Row="0"
            Margin="0,24,36,24"
            FontSize="40"
            FontWeight="SemiBold"
            Text="安装软件" />

        <Grid Grid.Row="1">
            <ScrollViewer Height="Auto" VerticalAlignment="Top">
                <StackPanel x:Name="SoftwareListPanel" />
            </ScrollViewer>
        </Grid>

        <StackPanel
            x:Name="ProgressRingStackPanel"
            Grid.Row="2"
            Margin="0,0,0,40"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Orientation="Vertical"
            Visibility="Collapsed">
            <TextBlock
                x:Name="CurrentlyInstalling"
                Text="{x:Bind ViewModel.CurrentInstalling, Mode=OneWay}"
                TextAlignment="Center" />
            <ProgressBar
                x:Name="DownloadingProgressBar"
                Width="130"
                HorizontalAlignment="Left"
                Maximum="100"
                Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}" />
        </StackPanel>

        <Button
            x:Name="InstallButton"
            Grid.Row="2"
            Margin="0,0,36,20"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Click="InstallSelected_Click"
            Content="安装"
            Style="{StaticResource AccentButtonStyle}"
            IsEnabled="{x:Bind ViewModel.IsInstalling, Mode=OneWay, Converter={StaticResource InvertBoolConverter}}" />
    </Grid>
</Page>
