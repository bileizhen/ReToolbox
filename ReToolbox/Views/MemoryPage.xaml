<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ReToolbox.Views.MemoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:services="using:ReToolbox.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style
            x:Key="AtlasLikeSettingsCardTemplate"
            BasedOn="{StaticResource ConfigurationSettingsCardTemplate}"
            TargetType="controls:SettingsCard">
            <Setter Property="Margin" Value="0,0,36,10" />
            <Setter Property="MinHeight" Value="80" />
            <Setter Property="BorderBrush" Value="#0DFFFFFF" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="CategoryTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </Page.Resources>

    <Grid Margin="55,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,24,36,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="内存管理" />

            <Button
                Grid.Column="1"
                VerticalAlignment="Center"
                Click="Refresh_Click"
                Content="刷新" />
        </Grid>

        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <!-- Dashboard -->
                <Grid Margin="0,8,36,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <FontIcon
                        Width="78"
                        Height="78"
                        Margin="0,0,22,0"
                        FontSize="54"
                        Foreground="#2AA8FF"
                        Glyph="&#xE964;" />

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="10">
                        <StackPanel Spacing="4">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Text="物理内存" />
                                <TextBlock
                                    Grid.Column="2"
                                    FontSize="14"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind ViewModel.PhysicalSummary, Mode=OneWay}" />
                            </Grid>
                            <ProgressBar
                                Maximum="100"
                                Value="{x:Bind ViewModel.PhysicalLoadPercent, Mode=OneWay}" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.AdminHint, Mode=OneWay}" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Text="提交(虚拟内存)" />
                                <TextBlock
                                    Grid.Column="2"
                                    FontSize="14"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind ViewModel.VirtualSummary, Mode=OneWay}" />
                            </Grid>
                            <ProgressBar
                                Maximum="100"
                                Value="{x:Bind ViewModel.VirtualLoadPercent, Mode=OneWay}" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.CommitSummary, Mode=OneWay}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Memory clean -->
                <TextBlock
                    Margin="0,4,36,10"
                    Style="{StaticResource CategoryTitle}"
                    Text="内存清理" />

                <controls:SettingsCard
                    Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                    Description="轻量清理:削减各进程工作集，安全快速。"
                    Header="轻量清理">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE950;" />
                    </controls:SettingsCard.HeaderIcon>
                    <Button
                        Click="LightClean_Click"
                        Content="轻量清理"
                        IsEnabled="{x:Bind ViewModel.IsAdmin, Mode=OneWay}" />
                </controls:SettingsCard>

                <controls:SettingsCard
                    Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                    Description="深度清理:在轻量清理基础上清空系统文件缓存，释放更多内存，可能短暂卡顿。"
                    Header="深度清理">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE72C;" />
                    </controls:SettingsCard.HeaderIcon>
                    <Button
                        Click="DeepClean_Click"
                        Content="深度清理"
                        IsEnabled="{x:Bind ViewModel.IsAdmin, Mode=OneWay}" />
                </controls:SettingsCard>

                <controls:SettingsCard
                    Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                    Description="清理后内存数字会随程序使用而回升，属正常现象。"
                    Header="上次清理结果">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </controls:SettingsCard.HeaderIcon>
                    <TextBlock
                        VerticalAlignment="Center"
                        TextWrapping="WrapWholeWords"
                        Text="{x:Bind ViewModel.LastCleanText, Mode=OneWay}" />
                </controls:SettingsCard>

                <ProgressBar
                    x:Name="CleanProgress"
                    Margin="0,6,36,12"
                    IsIndeterminate="True"
                    Visibility="Collapsed" />

                <!-- Virtual memory -->
                <TextBlock
                    Margin="0,8,36,10"
                    Style="{StaticResource CategoryTitle}"
                    Text="虚拟内存(分页文件)" />

                <controls:SettingsCard
                    Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                    Header="当前状态"
                    Description="本机当前分页文件配置。">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE950;" />
                    </controls:SettingsCard.HeaderIcon>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.PagefileStatus, Mode=OneWay}" />
                </controls:SettingsCard>

                <controls:SettingsCard
                    Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                    Header="推荐方案"
                    Description="{x:Bind ViewModel.PagefileRecommendation, Mode=OneWay}">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </controls:SettingsCard.HeaderIcon>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <RadioButton
                            x:Name="StandardPresetRadio"
                            GroupName="Preset"
                            Content="普通"
                            Checked="Preset_Changed"
                            IsChecked="True" />
                        <RadioButton
                            x:Name="HardcorePresetRadio"
                            GroupName="Preset"
                            Content="高级"
                            Checked="Preset_Changed" />
                        <Button
                            x:Name="AutoAllocateButton"
                            Click="AutoAllocate_Click"
                            Content="自动分配"
                            IsEnabled="{x:Bind ViewModel.IsAdmin, Mode=OneWay}"
                            Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard
                    Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                    Description="设置分页文件的最小/最大值(MB)，修改后需重启生效。留空使用推荐值。"
                    Header="自定义大小">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE7BA;" />
                    </controls:SettingsCard.HeaderIcon>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <NumberBox
                            x:Name="MinBox"
                            Width="120"
                            Header="最小 (MB)"
                            Value="{x:Bind ViewModel.RecommendedMinMb, Mode=OneWay}" />
                        <NumberBox
                            x:Name="MaxBox"
                            Width="120"
                            Header="最大 (MB)"
                            Value="{x:Bind ViewModel.RecommendedMaxMb, Mode=OneWay}" />
                        <Button
                            VerticalAlignment="Bottom"
                            Click="ApplyPagefile_Click"
                            Content="应用"
                            IsEnabled="{x:Bind ViewModel.IsAdmin, Mode=OneWay}" />
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard
                    Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                    Description="交由 Windows 自动管理分页文件大小(推荐大多数用户)。"
                    Header="恢复系统管理">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE72C;" />
                    </controls:SettingsCard.HeaderIcon>
                    <Button
                        Click="RestorePagefile_Click"
                        Content="恢复"
                        IsEnabled="{x:Bind ViewModel.IsAdmin, Mode=OneWay}" />
                </controls:SettingsCard>

                <TextBlock
                    x:Name="PagefileResultText"
                    Margin="0,0,36,10"
                    FontSize="13"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.PagefileResultText, Mode=OneWay}"
                    Visibility="{x:Bind PagefileResultVisibility, Mode=OneWay}" />

                <!-- Auto clean -->
                <TextBlock
                    Margin="0,8,36,10"
                    Style="{StaticResource CategoryTitle}"
                    Text="定时自动清理" />

                <controls:SettingsCard
                    Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                    Description="开启后在应用运行期间全程后台按设定间隔自动清理，关闭页面也不影响。"
                    Header="启用自动清理">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE916;" />
                    </controls:SettingsCard.HeaderIcon>
                    <ToggleSwitch
                        x:Name="AutoCleanToggle"
                        Toggled="AutoCleanToggle_Toggled"
                        OffContent="关"
                        OnContent="开" />
                </controls:SettingsCard>

                <controls:SettingsCard
                    Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                    Description="两次清理之间的间隔(分钟)。"
                    Header="清理间隔">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE923;" />
                    </controls:SettingsCard.HeaderIcon>
                    <NumberBox
                        x:Name="IntervalBox"
                        Width="140"
                        Minimum="1"
                        Maximum="1440"
                        SpinButtonPlacementMode="Compact"
                        ValueChanged="IntervalBox_ValueChanged"
                        Header="分钟" />
                </controls:SettingsCard>

                <controls:SettingsCard
                    Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                    Description="轻量清理仅削减进程工作集;深度清理额外清空系统文件缓存，释放更多但可能短暂卡顿。"
                    Header="清理类型">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE950;" />
                    </controls:SettingsCard.HeaderIcon>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <RadioButton
                            x:Name="LightCleanRadio"
                            GroupName="AutoCleanType"
                            Content="轻量"
                            Checked="CleanType_Changed"
                            IsChecked="True" />
                        <RadioButton
                            x:Name="DeepCleanRadio"
                            GroupName="AutoCleanType"
                            Content="深度"
                            Checked="CleanType_Changed" />
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard
                    Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                    Description="仅当物理内存占用超过此阈值时才触发清理，避免无意义频繁清理。设为 0 表示每次都清理。"
                    Header="内存占用阈值">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </controls:SettingsCard.HeaderIcon>
                    <Slider
                        x:Name="ThresholdSlider"
                        Width="200"
                        Minimum="0"
                        Maximum="100"
                        StepFrequency="5"
                        SnapsTo="StepValues"
                        ValueChanged="ThresholdSlider_ValueChanged"
                        Header="占用百分比" />
                </controls:SettingsCard>

                <TextBlock
                    x:Name="AutoCleanStatusText"
                    Margin="0,0,36,10"
                    FontSize="13"
                    Text="{x:Bind ViewModel.AutoCleanStatus, Mode=OneWay}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <!-- Process ranking -->
                <TextBlock
                    Margin="0,8,36,10"
                    Style="{StaticResource CategoryTitle}"
                    Text="进程内存占用排行" />

                <ItemsRepeater Margin="0,0,36,24" ItemsSource="{x:Bind ViewModel.TopProcesses, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="services:ProcessMemoryEntry">
                            <controls:SettingsCard
                                Margin="0,0,0,6"
                                Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                                Description="{x:Bind DisplayText, Mode=OneWay}"
                                Header="{x:Bind ProcessName, Mode=OneWay}">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xE7B4;" />
                                </controls:SettingsCard.HeaderIcon>
                                <Button
                                    Click="TrimProcess_Click"
                                    Content="削减"
                                    Tag="{x:Bind ProcessId, Mode=OneWay}" />
                            </controls:SettingsCard>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </ScrollViewer>

        <InfoBar
            x:Name="StatusInfoBar"
            Grid.RowSpan="2"
            MaxWidth="420"
            Margin="0,0,36,24"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            IsClosable="True"
            IsOpen="False"
            Title="" />
    </Grid>
</Page>
