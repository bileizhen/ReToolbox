<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ReToolbox.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ReToolbox.Controls"
    xmlns:controls1="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Margin="0,0,0,40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Margin="0,20,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <controls:HomePageHeaderImage
                    Grid.RowSpan="2"
                    Height="396"
                    VerticalAlignment="Top" />

                <StackPanel
                    Margin="50,0,0,0"
                    VerticalAlignment="Center"
                    Orientation="Vertical"
                    Spacing="6">
                    <TextBlock
                        FontSize="18"
                        Foreground="White"
                        Text="ReToolbox 重装工具箱" />
                    <TextBlock
                        FontSize="46"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="主页" />
                    <TextBlock
                        FontSize="14"
                        Foreground="#CCFFFFFF"
                        Text="{x:Bind ViewModel.SystemSummary, Mode=OneWay}" />
                </StackPanel>

                <controls:TileGallery
                    x:Name="TileGalleryControl"
                    Grid.Row="1"
                    Margin="15,0,0,0" />
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,32,0,0" Spacing="12">
                <TextBlock
                    Margin="24,0,0,0"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="功能概览" />

                <controls1:SettingsCard
                    Margin="24,0,24,0"
                    Description="批量安装常用软件，如 Chrome、VS Code、Git 等"
                    Header="安装软件"
                    Style="{StaticResource ConfigurationSettingsCardTemplate}">
                    <controls1:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE896;" />
                    </controls1:SettingsCard.HeaderIcon>
                    <Button Click="NavigateToSoftware" Content="前往" Style="{StaticResource AccentButtonStyle}" />
                </controls1:SettingsCard>

                <controls1:SettingsCard
                    Margin="24,0,24,0"
                    Description="使用 MAS 一键激活 Windows 系统"
                    Header="系统激活"
                    Style="{StaticResource ConfigurationSettingsCardTemplate}">
                    <controls1:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE8F1;" />
                    </controls1:SettingsCard.HeaderIcon>
                    <Button Click="NavigateToActivation" Content="前往" Style="{StaticResource AccentButtonStyle}" />
                </controls1:SettingsCard>

                <controls1:SettingsCard
                    Margin="24,0,24,0"
                    Description="管理 Windows 更新、驱动更新和暂停策略"
                    Header="管理更新"
                    Style="{StaticResource ConfigurationSettingsCardTemplate}">
                    <controls1:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE895;" />
                    </controls1:SettingsCard.HeaderIcon>
                    <Button Click="NavigateToWindowsUpdate" Content="前往" Style="{StaticResource AccentButtonStyle}" />
                </controls1:SettingsCard>

                <controls1:SettingsCard
                    Margin="24,0,24,0"
                    Description="安装、卸载和清理 Microsoft Edge 浏览器"
                    Header="管理 Edge"
                    Style="{StaticResource ConfigurationSettingsCardTemplate}">
                    <controls1:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE774;" />
                    </controls1:SettingsCard.HeaderIcon>
                    <Button Click="NavigateToEdgeRemover" Content="前往" Style="{StaticResource AccentButtonStyle}" />
                </controls1:SettingsCard>

                <controls1:SettingsCard
                    Margin="24,0,24,0"
                    Description="查看 CPU、内存、磁盘空间与系统运行状态"
                    Header="系统信息"
                    Style="{StaticResource ConfigurationSettingsCardTemplate}">
                    <controls1:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE770;" />
                    </controls1:SettingsCard.HeaderIcon>
                    <Button Click="NavigateToSystemInfo" Content="前往" Style="{StaticResource AccentButtonStyle}" />
                </controls1:SettingsCard>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
