<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ReToolbox.Views.WindowsUpdatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style
            x:Key="AtlasLikeSettingsCardTemplate"
            BasedOn="{StaticResource ConfigurationSettingsCardTemplate}"
            TargetType="controls:SettingsCard">
            <Setter Property="Margin" Value="0,0,36,10" />
            <Setter Property="MinHeight" Value="80" />
            <Setter Property="BorderBrush" Value="#0DFFFFFF" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

    </Page.Resources>

    <Grid Margin="55,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Margin="0,24,0,8"
            Style="{StaticResource TitleTextBlockStyle}"
            Text="管理更新" />

        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <Grid Margin="0,8,36,34">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Width="78" Height="78" Margin="0,0,22,0">
                        <FontIcon
                            FontSize="54"
                            Foreground="#2AA8FF"
                            Glyph="&#xE895;" />
                        <Border
                            Width="24"
                            Height="24"
                            Margin="0,0,4,6"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Background="{x:Bind ViewModel.SummaryBadgeBackground, Mode=OneWay}"
                            CornerRadius="12">
                            <Grid>
                                <FontIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="{x:Bind ViewModel.SummaryBadgeForeground, Mode=OneWay}"
                                    Glyph="{x:Bind ViewModel.SummaryBadgeGlyph, Mode=OneWay}"
                                    Visibility="{x:Bind GetFontBadgeVisibility(ViewModel.SummaryBadgeKind), Mode=OneWay}" />
                                <Grid
                                    Width="10"
                                    Height="10"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{x:Bind GetPauseBadgeVisibility(ViewModel.SummaryBadgeKind), Mode=OneWay}">
                                    <Rectangle
                                        Width="3"
                                        Height="10"
                                        HorizontalAlignment="Left"
                                        Fill="White"
                                        RadiusX="1"
                                        RadiusY="1" />
                                    <Rectangle
                                        Width="3"
                                        Height="10"
                                        HorizontalAlignment="Right"
                                        Fill="White"
                                        RadiusX="1"
                                        RadiusY="1" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="10">
                        <TextBlock
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.SummaryTitle, Mode=OneWay}" />
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="15"
                                Text="{x:Bind ViewModel.SummarySubtitle, Mode=OneWay}" />
                            <TextBlock
                                Grid.Column="1"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.SummaryDetail, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>
                    </StackPanel>
                </Grid>

                <controls:SettingsCard
                    Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                    Description="通过组织策略长期禁用自动更新，并限制系统设置中的手动检查更新入口"
                    Header="策略禁更">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE895;" />
                    </controls:SettingsCard.HeaderIcon>
                    <ToggleSwitch
                        x:Name="PauseToggle"
                        IsOn="{x:Bind ViewModel.IsUpdatePaused, Mode=TwoWay}"
                        Toggled="PauseToggle_Toggled" />
                </controls:SettingsCard>

                <controls:SettingsCard
                    Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                    Description="打开后把系统暂停更新时长扩展到 10 年，关闭后清除这组暂停设置"
                    Header="暂停 10 年">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE823;" />
                    </controls:SettingsCard.HeaderIcon>
                    <ToggleSwitch
                        x:Name="TenYearPauseToggle"
                        IsOn="{x:Bind ViewModel.IsTenYearPauseEnabled, Mode=TwoWay}"
                        Toggled="TenYearPauseToggle_Toggled" />
                </controls:SettingsCard>

                <controls:SettingsCard
                    Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                    Description="阻止 Windows Update 自动安装驱动程序更新"
                    Header="禁用驱动更新">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE968;" />
                    </controls:SettingsCard.HeaderIcon>
                    <ToggleSwitch
                        x:Name="DriverToggle"
                        IsOn="{x:Bind ViewModel.AreDriverUpdatesDisabled, Mode=TwoWay}"
                        Toggled="DriverToggle_Toggled" />
                </controls:SettingsCard>

                <controls:SettingsCard
                    Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                    Description="清理 Windows Update 禁更策略、暂停时间和相关限制项"
                    Header="恢复默认策略">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE72C;" />
                    </controls:SettingsCard.HeaderIcon>
                    <Button
                        x:Name="ResetPoliciesButton"
                        Click="ResetPolicies_Click"
                        Content="恢复默认"
                        Style="{StaticResource AccentButtonStyle}" />
                </controls:SettingsCard>
            </StackPanel>
        </ScrollViewer>

        <InfoBar
            x:Name="StatusInfoBar"
            Grid.RowSpan="2"
            MaxWidth="420"
            Margin="0,0,36,24"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            IsClosable="True"
            IsOpen="False"
            Opacity="0"
            Title="">
            <InfoBar.RenderTransform>
                <TranslateTransform Y="18" />
            </InfoBar.RenderTransform>
        </InfoBar>
    </Grid>
</Page>
