<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ReToolbox.Views.ActivationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style
            x:Key="AtlasLikeSettingsCardTemplate"
            BasedOn="{StaticResource ConfigurationSettingsCardTemplate}"
            TargetType="controls:SettingsCard">
            <Setter Property="Margin" Value="0,0,36,10" />
            <Setter Property="MinHeight" Value="80" />
            <Setter Property="BorderBrush" Value="#0DFFFFFF" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="CategoryTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

    </Page.Resources>

    <Grid Margin="55,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Margin="0,24,0,8"
            Style="{StaticResource TitleTextBlockStyle}"
            Text="系统激活" />

        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <Grid Margin="0,8,36,34">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Width="78" Height="78" Margin="0,0,22,0">
                        <Rectangle Width="36" Height="36" HorizontalAlignment="Left" VerticalAlignment="Top" Fill="#F3F3F3" />
                        <Rectangle Width="36" Height="36" HorizontalAlignment="Right" VerticalAlignment="Top" Fill="#F3F3F3" />
                        <Rectangle Width="36" Height="36" HorizontalAlignment="Left" VerticalAlignment="Bottom" Fill="#F3F3F3" />
                        <Rectangle Width="36" Height="36" HorizontalAlignment="Right" VerticalAlignment="Bottom" Fill="#F3F3F3" />
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="10">
                        <TextBlock
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.WindowsEdition, Mode=OneWay}" />
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="15"
                                Text="{x:Bind ViewModel.ActivationStatusText, Mode=OneWay}" />
                            <FontIcon
                                Grid.Column="1"
                                Margin="0,0,2,0"
                                VerticalAlignment="Center"
                                Foreground="{x:Bind ViewModel.ActivationStatusForeground, Mode=OneWay}"
                                Glyph="{x:Bind ViewModel.ActivationStatusGlyph, Mode=OneWay}" />
                            <TextBlock
                                Grid.Column="2"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.ActivationDetail, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>
                    </StackPanel>
                </Grid>

                <controls:SettingsCard
                    Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                    Description="打开 MAS 汉化版的中文菜单，可在其中激活 Windows 或切换版本（家庭版→专业版等）。"
                    Header="一键激活 / 切换版本">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE977;" />
                    </controls:SettingsCard.HeaderIcon>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            x:Name="ActivateButton"
                            Click="Activate_Click"
                            Content="激活 Windows"
                            Style="{StaticResource AccentButtonStyle}"
                            IsEnabled="{x:Bind ViewModel.IsActivating, Mode=OneWay, Converter={StaticResource InvertBoolConverter}}" />
                        <Button Click="RefreshStatus_Click" Content="刷新状态" />
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsExpander
                    Description="了解更多关于 MAS 激活工具"
                    Header="关于 MAS"
                    Margin="0,0,36,10"
                    BorderBrush="#0DFFFFFF">
                    <controls:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE946;" />
                    </controls:SettingsExpander.HeaderIcon>
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard Description="MAS 是一个开源的 Windows 和 Office 激活工具（GPL-3.0）" Header="MAS 官方项目">
                            <HyperlinkButton Content="访问 GitHub" NavigateUri="https://github.com/massgravel/Microsoft-Activation-Scripts" />
                        </controls:SettingsCard>
                        <controls:SettingsCard Description="由 cmontage 提供的中文汉化版，本应用调用的即为汉化版菜单" Header="MAS 汉化版">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <HyperlinkButton Content="GitHub" NavigateUri="https://github.com/cmontage/mas-cn" />
                                <HyperlinkButton Content="Gitee 镜像" NavigateUri="https://gitee.com/cmontage/mas-cn" />
                            </StackPanel>
                        </controls:SettingsCard>
                        <controls:SettingsCard Description="支持 Windows 和 Office 的永久激活" Header="支持的产品">
                            <TextBlock VerticalAlignment="Center" Text="Windows 10/11, Office 2016-2024" />
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>
            </StackPanel>
        </ScrollViewer>

        <InfoBar
            x:Name="StatusInfoBar"
            Grid.RowSpan="2"
            MaxWidth="420"
            Margin="0,0,36,24"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            IsClosable="True"
            IsOpen="False"
            Title="" />
    </Grid>
</Page>
