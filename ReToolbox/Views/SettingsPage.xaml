<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ReToolbox.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Margin="55,0,0,0">
            <TextBlock
                Margin="0,24,0,30"
                Style="{StaticResource TitleTextBlockStyle}"
                Text="设置" />

            <TextBlock Style="{StaticResource SettingsCategoryTitleStyle}" Text="应用" />
            <controls:SettingsCard
                Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                Description="{x:Bind ViewModel.Description, Mode=OneWay}"
                Header="关于">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE946;" />
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>

            <controls:SettingsCard
                Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                Header="版本">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE946;" />
                </controls:SettingsCard.HeaderIcon>
                <TextBlock VerticalAlignment="Center" Text="{x:Bind ViewModel.Version, Mode=OneWay}" />
            </controls:SettingsCard>

            <controls:SettingsCard
                Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                Description="查看源代码、提交 Issue 或参与贡献"
                Header="GitHub">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8A7;" />
                </controls:SettingsCard.HeaderIcon>
                <HyperlinkButton Content="打开仓库" NavigateUri="{x:Bind ViewModel.GithubLink, Mode=OneWay}" />
            </controls:SettingsCard>

            <TextBlock Style="{StaticResource SettingsCategoryTitleStyle}" Text="技术信息" />
            <controls:SettingsCard
                Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                Description="基于 WinUI 3 / Windows App SDK 构建"
                Header="技术栈">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE943;" />
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>

            <controls:SettingsCard
                Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                Description="此工具仅供学习和个人使用，部分功能需要管理员权限"
                Header="免责声明">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE7BA;" />
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>
        </StackPanel>
    </ScrollViewer>
</Page>
