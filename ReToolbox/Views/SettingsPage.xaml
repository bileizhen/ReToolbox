<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ReToolbox.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style
            x:Key="AtlasLikeSettingsCardTemplate"
            BasedOn="{StaticResource ConfigurationSettingsCardTemplate}"
            TargetType="controls:SettingsCard">
            <Setter Property="Margin" Value="0,0,36,10" />
            <Setter Property="MinHeight" Value="80" />
            <Setter Property="BorderBrush" Value="#0DFFFFFF" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="CategoryTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Margin="55,0,0,0">
            <TextBlock
                Margin="0,24,0,30"
                Style="{StaticResource TitleTextBlockStyle}"
                Text="设置" />

            <TextBlock Style="{StaticResource CategoryTitle}" Text="应用" />
            <controls:SettingsCard
                Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                Description="下载 GitHub 资源时自动尝试镜像加速，失败自动切换"
                Header="GitHub 镜像加速">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE774;" />
                </controls:SettingsCard.HeaderIcon>
                <ToggleSwitch
                    IsOn="{x:Bind ViewModel.IsGitHubMirrorEnabled, Mode=TwoWay}" />
            </controls:SettingsCard>

            <controls:SettingsCard
                Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                Description="可从预设选择或输入自定义镜像地址，留空则自动尝试"
                Header="下载镜像"
                IsEnabled="{x:Bind ViewModel.IsGitHubMirrorEnabled, Mode=OneWay}">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE896;" />
                </controls:SettingsCard.HeaderIcon>
                <ComboBox
                    IsEditable="True"
                    ItemsSource="{x:Bind ViewModel.MirrorPresets, Mode=OneWay}"
                    Text="{x:Bind ViewModel.SelectedMirror, Mode=TwoWay}"
                    PlaceholderText="自动（留空则按顺序自动尝试）"
                    MinWidth="280" />
            </controls:SettingsCard>

            <controls:SettingsCard
                Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                Description="ReToolbox - Windows 重装后一键配置工具"
                Header="关于">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE946;" />
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>

            <controls:SettingsCard
                Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                Header="版本">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE946;" />
                </controls:SettingsCard.HeaderIcon>
                <TextBlock VerticalAlignment="Center" Text="{x:Bind ViewModel.Version, Mode=OneWay}" />
            </controls:SettingsCard>

            <TextBlock Style="{StaticResource CategoryTitle}" Text="技术信息" />
            <controls:SettingsCard
                Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                Description="基于 WinUI 3 / Windows App SDK 构建"
                Header="技术栈">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE943;" />
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>

            <controls:SettingsCard
                Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                Description="此工具仅供学习和个人使用"
                Header="免责声明">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE7BA;" />
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>
        </StackPanel>
    </ScrollViewer>
</Page>
