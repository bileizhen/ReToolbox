<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ReToolbox.Views.SystemInfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Margin="55,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,24,36,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="系统信息" />

            <Button
                Grid.Column="1"
                VerticalAlignment="Center"
                Click="Refresh_Click"
                Content="刷新" />
        </Grid>

        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <Grid Margin="0,8,36,34">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <FontIcon
                        Width="78"
                        Height="78"
                        Margin="0,0,22,0"
                        FontSize="54"
                        Foreground="#2AA8FF"
                        Glyph="&#xE770;" />

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="10">
                        <TextBlock
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.WindowsEdition, Mode=OneWay}" />
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="15"
                                Text="{x:Bind ViewModel.AdminStatusText, Mode=OneWay}" />
                            <FontIcon
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Foreground="{x:Bind ViewModel.AdminStatusForeground, Mode=OneWay}"
                                Glyph="{x:Bind ViewModel.AdminStatusGlyph, Mode=OneWay}" />
                            <TextBlock
                                Grid.Column="2"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.Architecture, Mode=OneWay}" />
                        </Grid>
                    </StackPanel>
                </Grid>

                <controls:SettingsCard
                    Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                    Description="{x:Bind ViewModel.ProcessorName, Mode=OneWay}"
                    Header="处理器">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE950;" />
                    </controls:SettingsCard.HeaderIcon>
                </controls:SettingsCard>

                <controls:SettingsCard
                    Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                    Description="{x:Bind ViewModel.MemoryText, Mode=OneWay}"
                    Header="内存">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE964;" />
                    </controls:SettingsCard.HeaderIcon>
                </controls:SettingsCard>

                <controls:SettingsCard
                    Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                    Description="{x:Bind ViewModel.UptimeText, Mode=OneWay}"
                    Header="系统运行时间">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE823;" />
                    </controls:SettingsCard.HeaderIcon>
                </controls:SettingsCard>

                <controls:SettingsCard
                    Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                    Header="计算机与用户">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE77B;" />
                    </controls:SettingsCard.HeaderIcon>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="{x:Bind ViewModel.ComputerName, Mode=OneWay}" />
                        <Run Text=" · " />
                        <Run Text="{x:Bind ViewModel.UserName, Mode=OneWay}" />
                    </TextBlock>
                </controls:SettingsCard>

                <TextBlock
                    Margin="0,8,36,10"
                    Style="{StaticResource CategoryTitleStyle}"
                    Text="磁盘空间" />

                <ItemsRepeater Margin="0,0,36,24" ItemsSource="{x:Bind ViewModel.Drives, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="services:DriveInfoItem" xmlns:services="using:ReToolbox.Services">
                            <controls:SettingsCard
                                Margin="0,0,0,10"
                                Style="{StaticResource AtlasLikeSettingsCardTemplate}"
                                Description="{x:Bind DetailText, Mode=OneWay}"
                                Header="{x:Bind HeaderText, Mode=OneWay}">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xEDA2;" />
                                </controls:SettingsCard.HeaderIcon>
                                <ProgressBar
                                    Width="120"
                                    Maximum="100"
                                    Value="{x:Bind UsedPercent, Mode=OneWay}" />
                            </controls:SettingsCard>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
